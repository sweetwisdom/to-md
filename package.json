{
  "name": "playwright-to-md",
  "version": "1.0.5",
  "description": "CLI tool to extract web content using SimpRead rules and convert to Markdown",
  "type": "module",
  "main": "lib/converter.mjs",
  "bin": {
    "to-md": "./bin/cli.mjs",
    "playwright-to-md": "./bin/cli.mjs"
  },
  "homepage": "https://github.com/sweetwisdom/to-md",
  "author": "sweetwisdom",
  "maintainers": [
    {
      "name": "sweetwisdom",
      "email": "sweetwisdom@foxmail.com",
      "web": "https://github.com/sweetwisdom"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sweetwisdom/to-md"
  },
  "files": [
    "bin/",
    "lib/",
    "data/",
    "README.md",
    "README_EN.md"
  ],
